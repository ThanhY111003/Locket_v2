# ================================================================
# LOCKET FINANCE — Environment Variables
# Sao chep file nay thanh .env va dien gia tri thuc cua ban
# KHONG commit file .env len Git!
# ================================================================

# ===== Database =====
DB_URL=jdbc:postgresql://localhost:5432/locket_finance
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password_here

# ===== JWT =====
# Tao ngau nhien tai: https://generate.plus/en/base64 (chon 64 bytes)
JWT_SECRET=locket-finance-super-secret-key-please-change-this-in-production!!
JWT_EXPIRATION=86400000

# ===== Cloudinary =====
# Lay tai: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== Google Gemini AI =====
# Lay tai: https://aistudio.google.com/app/apikey
# De trong neu chua co (tinh nang AI se bi tat)
GEMINI_API_KEY=

# ===== Server =====
SERVER_PORT=8080

# ===== Upload =====
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=15MB
